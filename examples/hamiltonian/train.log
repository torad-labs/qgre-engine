│ - $ g = 9.8 $                                                                                                                        │
│                                                                                                                                      │
│ #### THEN:                                                                                                                           │
│                                                                                                                                      │
│ $$                                                                                                                                   │
│ T = \frac{p^2}{2m} = \frac{p^2}{2} \quad \text{OK}                                                                                   │
│ $$                                                                                                                                   │
│                                                                                                                                      │
│ $$                                                                                                                                   │
│ V = 3x^2 - 9.8x                                                                                                                      │
│ $$                                                                                                                                   │
